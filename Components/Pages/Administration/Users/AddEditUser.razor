@using SGC_Database_Backup.Components.Extensions
<LoadingOverlay IsLoading="@isLoading"/>
@if (userToEdit is not null)
{
    <EditForm Model="userToEdit" OnValidSubmit="Save">
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem" class="mb-2">
            <RadzenText Text="Nombre de Usuario" TextStyle="TextStyle.Body2"/>
            <RadzenTextBox @bind-Value="userToEdit.Username"/>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem" class="mb-2">
            <RadzenText Text="Correo" TextStyle="TextStyle.Body2" />
            <RadzenTextBox @bind-Value="userToEdit.Email"  />
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem" class="mb-2">
                <RadzenText Text="Password" TextStyle="TextStyle.Body2" />
                <RadzenTextBox @bind-Value="userToEdit.PasswordHash" type="password" />
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenText Text="Estatus" TextStyle="TextStyle.Body2"/>
                <RadzenSwitch @bind-Value="userToEdit.IsActive"/>
            </RadzenStack>
        </RadzenStack>
        <!-- Botones alineados a la derecha -->
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" class="mt-3">
            <RadzenButton ButtonType="ButtonType.Button"
            Text="Cancelar"
            ButtonStyle="ButtonStyle.Light"
            Click="@Close" />
            <RadzenButton ButtonType="ButtonType.Submit"
            Text="Guardar"
            ButtonStyle="ButtonStyle.Primary"
            Icon="save"
            IsBusy="@isSaving" />
        </RadzenStack>
    </EditForm>
}