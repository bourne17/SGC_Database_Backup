@page "/connections/list"
@using SGC_Database_Backup.Components.Extensions
<LoadingOverlay IsLoading="@isLoading"/>
<ComponentHeader Title="Gestion de Usuarios" SubTitle="Gestiona la lista de usuarios" OnRefresh="LoadConnections" OnAdd="AddConnection"/>
<RadzenDataGrid Data="databaseOptions">
    <Columns>
        <RadzenDataGridColumn Property="Description" Title="Nombre" Width="160px" />
        <RadzenDataGridColumn Property="TypeEngineDescription" Title="Engine" Width="160px" />
        <RadzenDataGridColumn Property="Host" Title="Servidor" Width="160px" />
        <RadzenDataGridColumn Property="Port" Title="Puerto" Width="160px" />
        <RadzenDataGridColumn Property="UserName" Title="Usuario" Width="160px" />
        <RadzenDataGridColumn Context="context" Title="Estatus" Width="160px">
            <Template>
                @if (context.IsActive)
                {
                    <RadzenChip Text="Activo" ChipStyle="BadgeStyle.Success" />
                }
                else

                {
                    <RadzenChip Text="Suspendido" ChipStyle="BadgeStyle.Danger" />

                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Context="context" Title="Acciones" Width="160px">
            <Template>
                <RadzenButton Icon="plug_connect" Click="@(() => TestConnection(context))" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" title="probar conexion"/>
                <RadzenButton Click="@(() => EditConnection(context.Id))" Icon="edit" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small" title="Editar"/>
                <RadzenButton Icon="delete_forever" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" title="Eliminar conexion"/>
            </Template>
        </RadzenDataGridColumn>

    </Columns>
</RadzenDataGrid>