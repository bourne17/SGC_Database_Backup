@if (IsLoading)
{
    <div class="custom-loading-backdrop">
        <div class="custom-loading-box">
            <div class="custom-spinner"></div>
            <span class="custom-loading-text">Cargando datos...</span>
        </div>
    </div>

    <div class="custom-loading-content-disabled">
        @ChildContent
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}

<style>
    /* Fondo translúcido FIJO que ocupa el 100% de la pantalla visible */
    .custom-loading-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.4); /* Un tono oscuro sutil para dar contraste */
        z-index: 9999; /* Prioridad máxima por encima de navbars y modales */
        display: flex;
        align-items: center; /* Centrado Vertical */
        justify-content: center; /* Centrado Horizontal */
    }

    /* Caja blanca flotante centralizada */
    .custom-loading-box {
        background-color: #ffffff;
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        min-width: 200px;
    }

    /* Animación del Spinner */
    .custom-spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid #007bff; /* Color azul estándar */
        border-radius: 50%;
        animation: spin-animation 1s linear infinite;
    }

    .custom-loading-text {
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 1.1rem;
        font-weight: 500;
        color: #333333;
    }

    /* Deshabilitar interacciones del fondo */
    .custom-loading-content-disabled {
        pointer-events: none;
        user-select: none;
        opacity: 0.6;
    }

    /* Escapamos la arroba para evitar el error CS0103 */
    @@keyframes spin-animation {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }
</style>