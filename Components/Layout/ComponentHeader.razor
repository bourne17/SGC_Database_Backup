<div class="page-header d-flex align-items-center justify-content-between gap-3 p-2">

    <HeaderTitle Title="@Title" SubTitle="@SubTitle" />

    <div class="header-actions d-inline-flex align-items-center gap-3 ms-auto">

        <ul class="table-top-head d-inline-flex align-items-center list-unstyled mb-0 gap-2 me-2">

            @* BOTÓN PDF - Condicional *@
            @if ( OnExportPDF.HasDelegate)
            {
                <li class="d-inline-flex align-items-center">
                    <RadzenButton Click="@HandleExportPDF"
                                  ButtonStyle="ButtonStyle.Base"
                                  Shade="Shade.Lighter"
                                  style="background-color:white;width: 36px; height: 36px; padding: 0; min-width: auto; display: inline-flex; align-items: center; justify-content: center;"
                                  class="pr-tooltip"
                                  data-pr-tooltip="Pdf"
                                  data-pr-position="top">

                        <svg width="16" height="20" viewBox="0 0 16 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block;">
                            <path d="M10 0H2C1.46957 0 0.960859 0.210714 0.585786 0.585786C0.210714 0.960859 0 1.46957 0 2V18C0 18.5304 0.210714 19.0391 0.585786 19.4142C0.960859 19.7893 1.46957 20 2 20H14C14.5304 20 15.0391 19.7893 15.4142 19.4142C15.7893 19.0391 16 18.5304 16 18V6L10 0ZM5.498 14.19C5.189 14.48 4.733 14.61 4.202 14.61C4.09904 14.6111 3.99613 14.6051 3.894 14.592V16.018H3V12.082C3.40345 12.0218 3.81112 11.9944 4.219 12C4.776 12 5.172 12.106 5.439 12.319C5.693 12.521 5.865 12.852 5.865 13.242C5.864 13.634 5.734 13.965 5.498 14.19ZM9.305 15.545C8.885 15.894 8.246 16.06 7.465 16.06C6.997 16.06 6.666 16.03 6.441 16V12.083C6.8446 12.0241 7.25214 11.9963 7.66 12C8.417 12 8.909 12.136 9.293 12.426C9.708 12.734 9.968 13.225 9.968 13.93C9.968 14.693 9.689 15.22 9.305 15.545ZM13 12.77H11.468V13.681H12.9V14.415H11.468V16.019H10.562V12.03H13V12.77ZM10 7H9V2L14 7H10Z" fill="#EA5455" />
                        </svg>

                    </RadzenButton>
                </li>
            }
            @* FIN BOTÓN PDF *@

            @* BOTÓN EXCEL - Condicional *@
            @if (OnExportExcel.HasDelegate)
            {
                <li class="d-inline-flex align-items-center">
                    <RadzenButton Click="@HandleExportExcel"
                                  ButtonStyle="ButtonStyle.Base"
                                  Shade="Shade.Lighter"
                                  style="background-color:white;width: 36px; height: 36px; padding: 0; min-width: auto; display: inline-flex; align-items: center; justify-content: center;"
                                  class="pr-tooltip"
                                  data-pr-tooltip="Excel"
                                  data-pr-position="top">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block;">
                            <path d="M21 5C21 3.897 20.103 3 19 3H5C3.897 3 3 3.897 3 5V19C3 20.103 3.897 21 5 21H19C20.103 21 21 20.103 21 19V5ZM5 19V5H19L19.002 19H5Z" fill="#28C76F" />
                            <path d="M7 7H8.998V9H7V7ZM11 7H17V9H11V7ZM7 11H8.998V13H7V11ZM11 11H17V13H11V11ZM7 15H8.998V17H7V15ZM11 15H17V17H11V15Z" fill="#28C76F" />
                        </svg>

                    </RadzenButton>
                </li>
            }
            @* FIN BOTÓN EXCEL *@


            <li class="d-inline-flex align-items-center">
                <RadzenButton ButtonStyle="ButtonStyle.Base"
                              Size="ButtonSize.Medium"
                              Click="@HandleRefresh"
                              Style="background-color: white; width: 36px; height: 36px; text-decoration: none; padding: 0; min-width: auto; display: inline-flex; align-items: center; justify-content: center;"
                              class="pr-tooltip"
                              data-pr-tooltip="Refresh"
                              data-pr-position="top">

                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" style="width: 20px; height: 20px; display: block;">
                        <path d="M129.9 292.5C143.2 199.5 223.3 128 320 128C373 128 421 149.5 455.8 184.2C456 184.4 456.2 184.6 456.4 184.8L464 192L416.1 192C398.4 192 384.1 206.3 384.1 224C384.1 241.7 398.4 256 416.1 256L544.1 256C561.8 256 576.1 241.7 576.1 224L576.1 96C576.1 78.3 561.8 64 544.1 64C526.4 64 512.1 78.3 512.1 96L512.1 149.4L500.8 138.7C454.5 92.6 390.5 64 320 64C191 64 84.3 159.4 66.6 283.5C64.1 301 76.2 317.2 93.7 319.7C111.2 322.2 127.4 310 129.9 292.6zM573.4 356.5C575.9 339 563.7 322.8 546.3 320.3C528.9 317.8 512.6 330 510.1 347.4C496.8 440.4 416.7 511.9 320 511.9C267 511.9 219 490.4 184.2 455.7C184 455.5 183.8 455.3 183.6 455.1L176 447.9L223.9 447.9C241.6 447.9 255.9 433.6 255.9 415.9C255.9 398.2 241.6 383.9 223.9 383.9L96 384C87.5 384 79.3 387.4 73.3 393.5C67.3 399.6 63.9 407.7 64 416.3L65 543.3C65.1 561 79.6 575.2 97.3 575C115 574.8 129.2 560.4 129 542.7L128.6 491.2L139.3 501.3C185.6 547.4 249.5 576 320 576C449 576 555.7 480.6 573.4 356.5z" fill="currentColor" />
                    </svg>

                </RadzenButton>
            </li>

        </ul> @* Cierre del ul *@

        <RadzenButton Icon="add_circle_outline" Text="Agregar" ButtonStyle="ButtonStyle.Warning" Click="HandleAdd" />
    </div>
</div>


@code {
    [Parameter]
    public string Title { get; set; } = "NO DISPONIBLE";
    [Parameter]
    public string SubTitle { get; set; } = "NO DISPONIBLE";

    // Los eventos deben aceptar el mismo tipo de parámetro, pero en este caso solo nos importa si fueron asignados.
    [Parameter]
    public EventCallback OnAdd { get; set; }
    [Parameter]
    public EventCallback OnRefresh { get; set; }

    [Parameter]
    public EventCallback OnExportExcel { get; set; } // <- Mantener

    [Parameter]
    public EventCallback OnExportPDF { get; set; }  // <- Mantener

    private async Task HandleExportExcel()
    {
        if (OnExportExcel.HasDelegate)
        {
            await OnExportExcel.InvokeAsync();
        }
    }
    private async Task HandleAdd()
    {
        if (OnAdd.HasDelegate)
        {
            await OnAdd.InvokeAsync();
        }
    }

    private async Task HandleRefresh()
    {
        if (OnRefresh.HasDelegate)
        {
            await OnRefresh.InvokeAsync();
        }
    }

    private async Task HandleExportPDF()
    {
        if (OnExportPDF.HasDelegate)
        {
            await OnExportPDF.InvokeAsync();
        }
    }
}